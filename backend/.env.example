# ============================================================
# Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ============================================================

# ---- Server ----
# Bind to 0.0.0.0 so your phone can reach the backend over Wi-Fi.
# DO NOT use 127.0.0.1 or localhost — those are unreachable from a phone.
HOST=0.0.0.0
PORT=8000

# ---- MongoDB ----
DATABASE_URL=mongodb://localhost:27017/dsa_assistant

# ---- JWT ----
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- OpenAI / Local LLM (Optional) ----
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# For LM Studio: OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_MODEL=gpt-3.5-turbo

# ---- Application ----
APP_NAME="AI DSA Learning Assistant"
APP_VERSION=1.0.0
DEBUG=True

# ---- Rate Limiting ----
RATE_LIMIT_PER_MINUTE=100

# ---- CORS ----
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081","http://localhost:8082"]

# ---- Redis (Optional) ----
# REDIS_URL=redis://localhost:6379