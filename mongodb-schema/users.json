{
  "_id": "ObjectId",
  "name": "String [required]",
  "email": "String [required, unique]",
  "password": "String [required, hashed]",
  "avatar": "String [optional, URL]",
  "role": "String [enum: 'user', 'admin', default: 'user']",
  "streak": {
    "current": "Number [default: 0]",
    "longest": "Number [default: 0]",
    "lastActiveDate": "Date"
  },
  "stats": {
    "totalSolved": "Number [default: 0]",
    "totalSubmissions": "Number [default: 0]",
    "joinDate": "Date [default: Date.now]",
    "lastLogin": "Date"
  },
  "preferences": {
    "difficulty": "String [enum: 'easy', 'medium', 'hard', 'mixed', default: 'mixed']",
    "dailyGoal": "Number [default: 3]",
    "notifications": "Boolean [default: true]"
  },
  "isActive": "Boolean [default: true]",
  "createdAt": "Date [default: Date.now]",
  "updatedAt": "Date [default: Date.now]"
}